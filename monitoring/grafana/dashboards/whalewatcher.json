{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "WhaleWatcher Overview",
  "uid": "whalewatcher",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Trades ingested / min",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(ww_trades_ingested_total[1m]))*60", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Whales detected (1h)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(increase(ww_whales_detected_total[1h]))", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Markets tracked",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(ww_markets_tracked)", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "WS connections",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "ww_api_ws_connections", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Alerts emitted by type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "sum by (type) (rate(ww_alerts_emitted_total[5m]))", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Engine job latency p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, queue) (rate(ww_engine_job_seconds_bucket[5m])))", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Collector errors",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [{ "expr": "sum by (platform, stage) (rate(ww_collect_errors_total[5m]))", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "API request rate by status",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [{ "expr": "sum by (status) (rate(ww_api_requests_total[5m]))", "refId": "A" }]
    }
  ]
}
