# ──────────────────────────────────────────────────────────────────────────
# WhaleWatcher — PRODUCTION env reference for Dokploy "separate apps" deploys.
#
# Unlike .env (one file, docker-compose), in Dokploy each Application has its
# OWN Environment tab. This file is a REFERENCE: copy the relevant block into
# each app. Values here are placeholders — fill them in.
#
#   • Postgres + Redis are Dokploy "Database" resources, NOT apps. Copy their
#     INTERNAL connection strings from the Dokploy database page.
#   • The web app's NEXT_PUBLIC_* are BUILD ARGS (baked at build time), not
#     runtime env. Set them under the web Application's Build settings.
#   • Never commit real secrets. This file is only an example.
# ──────────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════════════════
# COMMON — paste into EVERY node app (api, engine, collectors, bot)
# ════════════════════════════════════════════════════════════════════════════
# One image (docker/node.Dockerfile) runs all four node services; APP picks which
# one THIS container runs. It is REQUIRED — without it the container exits. Set
# the per-service value below (api/engine/collectors/bot), not here.
NODE_ENV=production
LOG_LEVEL=info
TZ=UTC

# From the Dokploy Postgres resource (internal host = its service name). Keep the
# pool small per app — each app opens its own pool against the shared DB.
DATABASE_URL=postgresql://whale:CHANGE_ME@whalewatcher-postgres:5432/whalewatcher?schema=public&connection_limit=15&pool_timeout=20

# From the Dokploy Redis resource (internal host = its service name).
REDIS_URL=redis://whalewatcher-redis:6379
REDIS_HOST=whalewatcher-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Detection thresholds (tune as real money arrives — see .env.example for notes).
WHALE_THRESHOLD_USD=5000
WHALE_MAX_PRICE=0.98
SPLIT_WINDOW_MS=900000
SPLIT_THRESHOLD_USD=5000
STEAM_MOVE_PCT=0.15
STEAM_WINDOW_MS=300000
STEAM_MIN_LIQUIDITY_USD=5000
STEAM_MIN_ABS_MOVE=0.02
# Only ALERT steam in markets with >= this volume (USD). Steam is also delivered
# to Telegram ONLY for chats that opted in via /live (never the broadcast chat).
STEAM_MIN_VOLUME_USD=50000
ARB_MIN_EDGE=0.05
WALLET_ALERT_MIN_STAKE_USD=25000

# Collector credentials / tuning (collectors needs these; harmless on others).
POLYGON_RPC_URL=https://polygon-rpc.com
# Discovery reads the EVENTS under these tags. 102232 = fifa-world-cup (PARENT —
# the only place per-game "X vs Y" markets live); 102350 = 2026 futures/props.
POLYMARKET_WC_TAG_IDS=102232,102350
# Hard rate cap: min ms between Polymarket requests (150 ≈ 6.6 req/s). Prevents
# data-api HTTP 429s regardless of COLLECTOR_CONCURRENCY. Raise if 429s persist.
POLYMARKET_MIN_REQUEST_MS=150
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
MANIFOLD_API_BASE=https://api.manifold.markets/v0
MANIFOLD_API_KEY=
MANIFOLD_USD_PER_MANA=0.07
API_FOOTBALL_KEY=CHANGE_ME
API_FOOTBALL_BASE=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026
API_FOOTBALL_INTERVAL_MS=3600000
API_FOOTBALL_MAX_PAGES=3
DISABLED_PLATFORMS=kalshi

# ── Polling cadence + trade ingestion filters ───────────────────────────────
# A live WC exposes ~10k Polymarket markets; these focus the engine on real money
# and keep a (rate-capped) poll pass inside its interval.
DISCOVERY_INTERVAL_MS=300000
TRADES_INTERVAL_MS=180000
ORDERBOOK_INTERVAL_MS=300000
# Track + poll only markets with >= this combined volume+liquidity (USD).
# $25k≈1557, $50k≈798, $100k≈438 markets. Match games are $100k–$28M, so they stay.
MIN_POLL_LIQUIDITY_USD=50000
# Drop dust trades below this USD (median trade ≈ $127). Lower (100) for more
# split sensitivity; raise if the queue lags.
MIN_TRADE_USD=250
# Track BUY trades only (sells are exit/unwind noise). true to include sells.
INGEST_SELLS=false
# Near-certainty cutoff: drop trades at/above this price and skip CONCLUDED match
# markets (a finished game sits at ~0.999). 1 = never skip on price.
MARKET_DECIDED_PRICE=0.98
# Max trade look-back (ms). Startup/recovery begin from recent LIVE activity, not
# a replayed missed window. MUST exceed TRADES_INTERVAL_MS. 10 min.
MAX_TRADE_LOOKBACK_MS=600000
# Max concurrent venue HTTP requests (the Polymarket rate cap also bounds rate).
# Lower if the collectors app is memory/CPU constrained on the VPS.
COLLECTOR_CONCURRENCY=5

# ════════════════════════════════════════════════════════════════════════════
# api — COMMON block + the following. Give this app a public domain (:4000).
# RUN_MIGRATIONS=true makes the container apply pending Prisma migrations on
# startup before booting (no custom run command needed). Set this ONLY on api so
# migrations run from a single service.
# ════════════════════════════════════════════════════════════════════════════
APP=api
RUN_MIGRATIONS=true
API_HOST=0.0.0.0
API_PORT=4000
# Comma-separated bearer tokens — generate: openssl rand -hex 32
API_KEYS=CHANGE_ME_LONG_RANDOM
# Must match the web app's public domain so browser calls pass CORS.
API_CORS_ORIGIN=https://app.your-domain.com

# ════════════════════════════════════════════════════════════════════════════
# bot — COMMON block + the following. No public domain (worker).
# ════════════════════════════════════════════════════════════════════════════
APP=bot
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_ALERT_CHAT_ID=CHANGE_ME
TELEGRAM_ADMIN_CHAT_IDS=CHANGE_ME
TELEGRAM_MIN_ALERT_USD=10000

# ════════════════════════════════════════════════════════════════════════════
# engine — COMMON block + the following. No public domain (worker).    APP=engine
# collectors — COMMON block + the following. No public domain (worker). APP=collectors
# Set APP to engine OR collectors respectively. METRICS_PORT is internal-only;
# expose to Prometheus on the private net if used.
# ════════════════════════════════════════════════════════════════════════════
APP=engine
METRICS_PORT=9100

# ════════════════════════════════════════════════════════════════════════════
# web — these are BUILD ARGS (Build settings), NOT the Environment tab, because
# NEXT_PUBLIC_* are inlined into the browser bundle at build time. Give this app
# a public domain (:3000).
# ════════════════════════════════════════════════════════════════════════════
# NEXT_PUBLIC_API_URL=https://api.your-domain.com
# NEXT_PUBLIC_WS_URL=wss://api.your-domain.com/ws
# NEXT_PUBLIC_API_KEY=<one of the API_KEYS values above>
