# ──────────────────────────────────────────────────────────────────────────
# WhaleWatcher environment. Copy to `.env` and fill in. Never commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
TZ=UTC

# ── Postgres (PostgreSQL 18) ────────────────────────────────────────────────
POSTGRES_USER=whale
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=whalewatcher
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Used by Prisma. In docker-compose the host is `postgres`.
DATABASE_URL=postgresql://whale:change_me_in_prod@localhost:5432/whalewatcher?schema=public&connection_limit=20

# ── Redis (cache + BullMQ) ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000
# Comma-separated bearer tokens accepted by protected endpoints.
API_KEYS=dev-local-key
# Secret used to sign internal service-to-service JWTs.
INTERNAL_JWT_SECRET=change_me_long_random_string

# ── Detection thresholds ──────────────────────────────────────────────────
# Single-trade whale threshold (USD).
WHALE_THRESHOLD_USD=300000
# Split-order accumulation window (ms) and aggregate threshold (USD).
SPLIT_WINDOW_MS=900000
SPLIT_THRESHOLD_USD=300000
# Steam move: % odds shift within window with no single qualifying whale trade.
STEAM_MOVE_PCT=0.05
STEAM_WINDOW_MS=300000
# Arbitrage: minimum edge (after fees) to flag, e.g. 0.02 = 2%.
ARB_MIN_EDGE=0.02

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Default broadcast channel/chat for high-priority alerts.
TELEGRAM_ALERT_CHAT_ID=
# Only allow these comma-separated chat ids to use admin commands (optional).
TELEGRAM_ADMIN_CHAT_IDS=

# ── Collector credentials ────────────────────────────────────────────────────
# Polymarket: public CLOB + Gamma APIs need no key for reads. On-chain (Polygon)
# enrichment is optional.
POLYGON_RPC_URL=https://polygon-rpc.com
# Kalshi: market data is public; trading endpoints need a key pair.
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# Manifold: public; key only needed for authenticated calls.
MANIFOLD_API_BASE=https://api.manifold.markets/v0
MANIFOLD_API_KEY=
# The Odds API (optional aggregator for Pinnacle/DK/FanDuel/Betfair odds).
ODDS_API_KEY=
ODDS_API_BASE=https://api.the-odds-api.com/v4
# Betfair (optional, requires app key + cert session).
BETFAIR_APP_KEY=
BETFAIR_SESSION_TOKEN=

# ── Polling intervals (ms) ──────────────────────────────────────────────────
DISCOVERY_INTERVAL_MS=300000
TRADES_INTERVAL_MS=15000
ORDERBOOK_INTERVAL_MS=5000

# ── Monitoring ────────────────────────────────────────────────────────────────
METRICS_PORT=9100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
