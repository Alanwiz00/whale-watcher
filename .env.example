# ──────────────────────────────────────────────────────────────────────────
# WhaleWatcher environment. Copy to `.env` and fill in. Never commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
TZ=UTC

# ── Postgres (PostgreSQL 18) ────────────────────────────────────────────────
POSTGRES_USER=whale
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=whalewatcher
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Used by Prisma. In docker-compose the host is `postgres`.
DATABASE_URL=postgresql://whale:change_me_in_prod@localhost:5432/whalewatcher?schema=public&connection_limit=30&pool_timeout=20

# ── Redis (cache + BullMQ) ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ── API ─────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=4000
API_CORS_ORIGIN=http://localhost:3000
# Comma-separated bearer tokens. When set, EVERY endpoint except infra
# (/health, /ready, /metrics) requires `Authorization: Bearer <token>` (or
# `?key=<token>` on the /ws handshake). Empty = auth off. Generate: openssl rand -hex 32
API_KEYS=dev-local-key

# ── Web dashboard ────────────────────────────────────────────────────────────
# Token the dashboard sends to the API — MUST be one of API_KEYS above. Baked
# into the browser bundle, so it's visible to dashboard users (not a secret);
# gate the dashboard's own access (proxy/VPN) if it must be private.
NEXT_PUBLIC_API_KEY=dev-local-key

# ── Detection thresholds ──────────────────────────────────────────────────
# Single-trade whale threshold (USD).
WHALE_THRESHOLD_USD=300000
# Ignore near-certainty buys (price >= this) — risk-free parking, not conviction.
WHALE_MAX_PRICE=0.98
# Split-order accumulation window (ms) and aggregate threshold (USD).
SPLIT_WINDOW_MS=900000
SPLIT_THRESHOLD_USD=300000
# Steam move: % odds shift within window with no single qualifying whale trade.
STEAM_MOVE_PCT=0.15
STEAM_WINDOW_MS=300000
# Min order-book liquidity (USD) for a market to qualify for steam detection.
STEAM_MIN_LIQUIDITY_USD=5000
# Min absolute probability shift (points) for steam (0.02 = 2 points). Stops
# long-shot noise where 0.1%→0.2% reads as a +100% relative move.
STEAM_MIN_ABS_MOVE=0.02
# Only ALERT on steam in markets with >= this cumulative volume (USD). Steam is
# still detected/recorded below this — it just won't ping. Filters thin longshot
# props. Each alert shows market size so you can tune. The steam analogue of
# TELEGRAM_MIN_ALERT_USD.
STEAM_MIN_VOLUME_USD=50000
# Arbitrage: minimum edge (after fees) to flag, e.g. 0.02 = 2%.
ARB_MIN_EDGE=0.02
# Smart-money wallet signal: only flag wallets staking >= this (USD).
WALLET_ALERT_MIN_STAKE_USD=25000

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Default broadcast channel/chat for high-priority alerts.
TELEGRAM_ALERT_CHAT_ID=
# Only allow these comma-separated chat ids to use admin commands (optional).
TELEGRAM_ADMIN_CHAT_IDS=
# Bot-only size gate (USD): Telegram pings only for whale/split alerts >= this,
# while the engine still detects/stores at the lower WHALE_THRESHOLD_USD. 0 = off.
TELEGRAM_MIN_ALERT_USD=0

# ── Collector credentials ────────────────────────────────────────────────────
# Polymarket: public CLOB + Gamma APIs need no key for reads. On-chain (Polygon)
# enrichment is optional.
POLYGON_RPC_URL=https://polygon-rpc.com
# Polymarket Gamma tag id(s) for the World Cup (comma-separated). Discovery reads
# the EVENTS under these. 102232 = fifa-world-cup (PARENT — only place per-game
# "X vs Y" markets live); 102350 = 2026-fifa-world-cup (futures/props). Keep both.
POLYMARKET_WC_TAG_IDS=102232,102350
# Kalshi: market data is public; trading endpoints need a key pair.
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# Manifold: public; key only needed for authenticated calls.
MANIFOLD_API_BASE=https://api.manifold.markets/v0
MANIFOLD_API_KEY=
# Approx USD value of 1 mana (~100 mana per $1). 0 = count mana 1:1 (legacy).
MANIFOLD_USD_PER_MANA=0.01
# API-Football (API-Sports): fixtures + per-bookmaker match odds for odds-only
# venues. Direct host uses x-apisports-key; RapidAPI host uses x-rapidapi-key.
API_FOOTBALL_KEY=
API_FOOTBALL_BASE=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026
# How often to hit API-Football (independent of discovery). Free tier ~100/day.
API_FOOTBALL_INTERVAL_MS=3600000
API_FOOTBALL_MAX_PAGES=3
# Betfair (optional, requires app key + cert session).
BETFAIR_APP_KEY=
BETFAIR_SESSION_TOKEN=

# Comma-separated platforms the collector registry should skip (e.g. "kalshi").
DISABLED_PLATFORMS=

# ── Polling intervals (ms) ──────────────────────────────────────────────────
# A live WC tracks thousands of markets, so widen these if the collector logs a
# pass taking longer than its interval (or raise MIN_POLL_LIQUIDITY_USD).
DISCOVERY_INTERVAL_MS=300000
TRADES_INTERVAL_MS=120000
ORDERBOOK_INTERVAL_MS=120000
# Min combined volume+liquidity (USD) for a market to be TRACKED (discovery) and
# polled. A live WC has ~10k Polymarket markets; this keeps the engine on the ones
# with real money so polling/DB aren't swamped. Raise (e.g. 25000) to poll fewer.
MIN_POLL_LIQUIDITY_USD=5000
# Don't enqueue trades below this USD size (dust). A live match has thousands of
# sub-$100 trades that can't be whales or split legs; one job each floods the
# queue (BullMQ "could not renew lock"). Lower for more split sensitivity.
MIN_TRADE_USD=100
# Max concurrent venue HTTP requests (lower = gentler on venue APIs).
COLLECTOR_CONCURRENCY=12

# ── Monitoring ────────────────────────────────────────────────────────────────
METRICS_PORT=9100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me
